{
  "name": "qa-dataset-workbench-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "node -e \"console.log('No backend tests configured')\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "npm run build && node dist/prisma/seed.js",
    "prisma:seed:docker": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.7.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "fastify-type-provider-zod": "^5.1.0",
    "mammoth": "^1.10.0",
    "jose": "^6.1.0",
    "openai": "^6.4.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
